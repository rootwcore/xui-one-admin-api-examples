# XUI.ONE Admin API base URL.
# Must end with a trailing slash.
XUI_BASE_URL=https://PANEL-DOMAIN:9000/ACCESSCODE/

# API key generated from the admin profile.
XUI_API_KEY=YOUR_ADMIN_API_KEY

# Recommended value for production: true.
# For a temporary self-signed test environment, you may set this to false.
XUI_VERIFY_SSL=true

# Example server ID for server-specific actions.
XUI_SERVER_ID=1
